{
  "name": "tradeStatusNotification",
  "entry": "entry.ts",
  "automations": [
    {
      "type": "entity",
      "description": "Sends email notifications to buyer and seller whenever a trade status changes.",
      "entity_name": "Trade",
      "event_types": [
        "update"
      ],
      "function_args": {
        "trade_id": "{{event.entity_id}}",
        "new_status": "{{data.status}}"
      },
      "is_active": true,
      "name": "Trade Status Email Notifications"
    }
  ]
}